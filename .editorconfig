# https://editorconfig.org/
#
# Canonical formatting settings for the repo. Enforced in CI by
# editorconfig-checker and read by tools like shfmt (>=3.4) directly.
# Editors that respect EditorConfig pick up the right settings for free.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yaml,yml,kyaml}]
indent_size = 2

[*.md]
# Markdown uses 2+ trailing spaces for hard line breaks.
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 4
# shfmt-specific keys (read directly by shfmt v3.4+):
switch_case_indent = true
binary_next_line = true

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
