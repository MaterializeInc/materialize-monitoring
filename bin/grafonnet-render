#!/usr/bin/env bash
# This generates a rendered jsonnet file
#
# Note: This is especially thin currently. It mostly just adds to
# the jsonnet path

set -e -o pipefail

SCRIPT=$(basename "$0")

# Show message to stderr
_log() {
    >&2 echo "$*"
}

_usage() {
    >&2 cat <<USAGE
Usage: ${SCRIPT} <target> [other args]
Example: ${SCRIPT} dashboard.jsonnet

See jsonnet --help for other args
USAGE
}

RENDER_ARGS=()

# Detect repo root (Don't need to get absolute path)
REPO_ROOT=$(cd "$(dirname "$0")/../" && pwd)
GRAFONNET_DIR=${REPO_ROOT}/tools/grafonnet

# rightmost takes precedence
JSONNET_PATH="${JSONNET_PATH:+${JSONNET_PATH}:}${GRAFONNET_DIR}/vendor:${GRAFONNET_DIR}/lib"

# Handle arguments passed in
_parse_args() {
    local arg
    while [ "$#" -gt 0 ]; do
        arg="$1"
        shift
        case "$arg" in
            --help|-h)
                _usage
                exit 0
                ;;
            -J|--jpath)
                if [ -z "$1" ]; then
                    _log "Error: $arg requires an argument"
                    exit 1
                fi
                # YAGNI: prefix into JSONNET_PATH as well?
                _log "Adding $1 to search"
                RENDER_ARGS+=("$arg" "$1")
                shift
                ;;
            *)
                # YAGNI: we don't need to be too argument aware _YET_
                RENDER_ARGS+=("$arg")
                ;;
        esac
    done
    if [ "${#RENDER_ARGS[@]}" -lt 1 ]; then
        _usage
        exit 1
    fi
}

# Render the jsonnet file with the given arguments
_do_render() {
    _log "Running JSONNET_PATH=${JSONNET_PATH} jsonnet ${RENDER_ARGS[*]}"
    JSONNET_PATH="$JSONNET_PATH" jsonnet "${RENDER_ARGS[@]}"
}

# Main entry point
_main() {
    _parse_args "$@"
    _do_render
}

_main "$@"
