Author: Heather Lapointe <heather.lapointe@materialize.com>
Date:   Fri Jul 3 17:48:18 2026 -0400

    Do not clear GOOS/GOARCH to avoid breaking if CC is set to cross compile

diff --git a/Makefile b/Makefile
index 0dfc4a8cd..2ac6a147f 100644
--- a/Makefile
+++ b/Makefile
@@ -336,7 +336,7 @@ generate-module-dependencies:
 ifeq ($(USE_CONTAINER),1)
 	$(RERUN_IN_CONTAINER)
 else
-	GOOS= GOARCH= go run -C tools ./cmd generate module-dependencies --dependency-yaml=$(CURDIR)/dependency-replacements.yaml
+	go run -C tools ./cmd generate module-dependencies --dependency-yaml=$(CURDIR)/dependency-replacements.yaml
 endif

 generate-source-code:
@@ -355,8 +355,7 @@ else
 	@if [ -f ./collector/go.mod ]; then \
 		cd ./collector && go mod tidy; \
 	fi
-	# Here we clear the GOOS and GOARCH env variables so we're not accidentally cross compiling the builder tool within generate
-	cd ./collector && GOOS= GOARCH= BUILDER_VERSION=$(BUILDER_VERSION) go generate
+	cd ./collector && BUILDER_VERSION=$(BUILDER_VERSION) go generate
 endif

 generate-ui:
