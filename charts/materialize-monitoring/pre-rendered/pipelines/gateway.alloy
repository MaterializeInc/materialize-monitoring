					target                       = "",
					trace_id                     = "",
					span_id                      = "",
					method                       = "",
					path                         = "",
					status_code                  = "",
					source                       = "",
					controller                   = "",
					resource_name                = "",
					error                        = "",
					request_header_host          = "",
					response_header_content_type = "",
				}
			}
		}

		stage.match {
			selector = "{container=\"new-promsql-exporter\"}"

			stage.static_labels {
				values = {
					app       = "mz-promsql-exporter",
					component = "mz-promsql-exporter",
				}
			}

			stage.json {
				expressions = {
					target           = "",
					level            = "",
					ts               = "timestamp",
					fields_message   = "fields.message",
					fields_msg       = "fields.msg",
					fields_error     = "fields.error",
					fields_err       = "fields.err",
					method           = "span.\"request.method\"",
					path             = "span.\"request.uri\"",
					request_headers  = "span.\"request.headers\"",
					status_code      = "span.\"response.status_code\"",
					response_headers = "span.\"response.headers\"",
					metadata         = "span.metadata",
					source           = "fields.source",
					controller       = "fields.controller",
