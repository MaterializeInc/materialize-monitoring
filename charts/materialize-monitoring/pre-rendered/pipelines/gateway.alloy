	stage.match {
		selector = "{app=\"external-dns\"}"

		stage.logfmt {
			mapping = {
				msg   = "msg",
				ts    = "time",
				level = "level",
			}
		}

		stage.timestamp {
			source = "ts"
			format = "RFC3339"
		}
	}

	stage.match {
		selector = "{app=\"tbot\"}"

		stage.json {
			expressions = {
				msg   = "message",
				level = "level",
				ts    = "timestamp",
			}
		}

		stage.timestamp {
			source = "ts"
			format = "RFC3339"
		}
	}

	stage.match {
		selector = "{namespace=~\"environment-.*\"}"

		stage.regex {
			expression = "^(?P<environment_name>environment-(?P<environment_id>.+)-\\d)$"
			source     = "namespace"
		}

		stage.structured_metadata {
			values = {
				environment_name  = "",
				organization_name = "",
				organization_id   = "environment_id",
			}
		}

		stage.labels {
			values = {
				environment_id = "environment_id",
			}
		}

		stage.static_labels {
			values = {
				__tenant_type = coalesce(sys.env("GATEWAY_TENANT_MAP_ENVIRONMENT"), "static"),
			}
		}

		stage.match {
			selector = "{container=\"environmentd\"}"

			stage.static_labels {
				values = {
					app       = "environmentd",
					component = "environmentd",
				}
			}

			stage.json {
				expressions = {
					target           = "",
					level            = "",
					ts               = "timestamp",
					fields_message   = "fields.message",
					fields_msg       = "fields.msg",
					fields_error     = "fields.error",
					fields_err       = "fields.err",
					method           = "span.\"request.method\"",
					path             = "span.\"request.uri\"",
					request_headers  = "span.\"request.headers\"",
					status_code      = "span.\"response.status_code\"",
					response_headers = "span.\"response.headers\"",
					metadata         = "span.metadata",
					source           = "fields.source",
					controller       = "fields.controller",
					resource_name    = "fields.resource_name",
					trace_id         = "trace_id",
					span_id          = "span_id",
				}
			}

			stage.template {
				source   = "error"
				template = "{{ if .fields_error }}{{ .fields_error }}{{ else if .fields_err }}{{ .fields_err }}{{ end }}"
			}

			stage.template {
				source   = "msg"
				template = "{{ if .fields_message }}{{ .fields_message }}{{ else if .fields_msg }}{{ .fields_msg }}{{ else }}{{ .error }}{{ end }}"
			}

			stage.json {
