					span_id                      = "",
					method                       = "",
					path                         = "",
					status_code                  = "",
					source                       = "",
					controller                   = "",
					resource_name                = "",
					error                        = "",
					request_header_host          = "",
					response_header_content_type = "",
				}
			}
		}

		stage.match {
			selector = "{container=\"clusterd\"}"

			stage.static_labels {
				values = {
					app       = "clusterd",
					component = "clusterd",
				}
			}

			stage.json {
				expressions = {
					target           = "",
					level            = "",
					ts               = "timestamp",
					fields_message   = "fields.message",
					fields_msg       = "fields.msg",
					fields_error     = "fields.error",
					fields_err       = "fields.err",
					method           = "span.\"request.method\"",
					path             = "span.\"request.uri\"",
					request_headers  = "span.\"request.headers\"",
					status_code      = "span.\"response.status_code\"",
					response_headers = "span.\"response.headers\"",
					metadata         = "span.metadata",
					source           = "fields.source",
					controller       = "fields.controller",
					resource_name    = "fields.resource_name",
					trace_id         = "trace_id",
					span_id          = "span_id",
				}
			}

			stage.template {
				source   = "error"
				template = "{{ if .fields_error }}{{ .fields_error }}{{ else if .fields_err }}{{ .fields_err }}{{ end }}"
			}

			stage.template {
				source   = "msg"
				template = "{{ if .fields_message }}{{ .fields_message }}{{ else if .fields_msg }}{{ .fields_msg }}{{ else }}{{ .error }}{{ end }}"
			}

			stage.json {
