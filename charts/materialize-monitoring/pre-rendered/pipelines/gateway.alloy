	stage.match {
		selector = "{app=\"balancer\"}"

		stage.json {
			expressions = {
				target           = "",
				level            = "",
				ts               = "timestamp",
				fields_message   = "fields.message",
				fields_msg       = "fields.msg",
				fields_error     = "fields.error",
				fields_err       = "fields.err",
				method           = "span.\"request.method\"",
				path             = "span.\"request.uri\"",
				request_headers  = "span.\"request.headers\"",
				status_code      = "span.\"response.status_code\"",
				response_headers = "span.\"response.headers\"",
				metadata         = "span.metadata",
				source           = "fields.source",
				controller       = "fields.controller",
				resource_name    = "fields.resource_name",
				trace_id         = "trace_id",
				span_id          = "span_id",
			}
		}

		stage.template {
			source   = "error"
			template = "{{ if .fields_error }}{{ .fields_error }}{{ else if .fields_err }}{{ .fields_err }}{{ end }}"
		}

		stage.template {
			source   = "msg"
			template = "{{ if .fields_message }}{{ .fields_message }}{{ else if .fields_msg }}{{ .fields_msg }}{{ else }}{{ .error }}{{ end }}"
		}

		stage.json {
			expressions = {
				request_header_host = "host",
			}
			source = "request_headers"
		}

		stage.json {
			expressions = {
				response_header_content_type = "\"content-type\"",
			}
			source = "response_headers"
		}

		stage.timestamp {
			source = "ts"
			format = "RFC3339Nano"
		}

		stage.structured_metadata {
			values = {
				target                       = "",
				trace_id                     = "",
				span_id                      = "",
				method                       = "",
				path                         = "",
				status_code                  = "",
				source                       = "",
				controller                   = "",
				resource_name                = "",
				error                        = "",
				request_header_host          = "",
				response_header_content_type = "",
			}
		}
	}

	stage.labels {
		values = {
			level = "level",
		}
	}

	stage.match {
		selector = "{level=\"UNKNOWN\"}"

		stage.regex {
			expression         = "(?i)\"?(?:level|severity)\"?\\s*[:=]\\s*\"?(?P<level>(?:info|warn|warning|err|error|debug|crit|critical|fatal))\"?"
			labels_from_groups = true
		}

		stage.template {
			source   = "levelheuristic"
			template = "{{ if eq .level \"UNKNOWN\" }}failed{{ else }}success{{ end }}"
		}

		stage.structured_metadata {
			values = {
				levelheuristic = "",
			}
		}
	}

	stage.replace {
		expression = "(?i)^(fatal|critical|crit|f)$"
		source     = "level"
		replace    = "CRITICAL"
	}

	stage.replace {
		expression = "(?i)^(error|err|e)$"
		source     = "level"
		replace    = "ERROR"
	}

	stage.replace {
		expression = "(?i)^(warn|warning|w)$"
		source     = "level"
		replace    = "WARN"
	}

	stage.replace {
		expression = "(?i)^(info|normal|notice|i)$"
		source     = "level"
		replace    = "INFO"
	}

	stage.replace {
		expression = "(?i)^(debug|dbg|v|vv)$"
		source     = "level"
		replace    = "DEBUG"
	}

	stage.replace {
		expression = "(?i)^(trace|verbose|vvv+)$"
		source     = "level"
		replace    = "TRACE"
	}

	stage.labels {
		values = {
			level = "level",
		}
	}

	stage.match {
		selector = "{__tenant_type=\"static\"}"

		stage.tenant {
			label = "__tenant_static"
		}
	}

	stage.match {
		selector = "{__tenant_type=\"byEnvironment\"}"

		stage.tenant {
			label = "environment_id"
		}
	}

	stage.match {
		selector = "{__tenant_type=\"byNamespace\"}"

		stage.tenant {
			label = "namespace"
		}
	}

	stage.match {
		selector = "{__tenant_type=\"byLabel\"}"

		stage.tenant {
			label = coalesce(sys.env("GATEWAY_TENANT_LABEL"), "__meta_kubernetes_pod_label_app_kubernetes_io_name")
		}
	}

	stage.match {
		selector = "{level=\"INFO\"}"

		stage.limit {
			rate  = 1000
			burst = 20000
			drop  = false
		}
	}

	stage.match {
		selector = "{level!~\"(CRITICAL|ERROR|WARN|INFO)\"}"

		stage.limit {
			rate          = 1000
			burst         = 5000
			drop          = true
			by_label_name = "namespace"
		}
	}

	stage.limit {
		rate  = 10000
		burst = 100000
		drop  = false
	}

	stage.drop {
		older_than          = "2h"
		drop_counter_reason = "processed time > 2hr old"
	}

	stage.structured_metadata_drop {
		values = [
			"orig_entry",
		]
	}

	stage.structured_metadata {
		values = {
			pod               = "",
			node              = "",
			pod_id            = "",
			container_id      = "",
			region            = "",
			zone              = "",
			nodepool          = "",
			node_workload     = "",
			instance_type     = "",
			container         = "",
			service_name      = "",
			organization_name = "",
			cluster           = "",
			stream            = "",
			pod_ready         = "",
			msg               = "",
		}
	}

	stage.labels {
		values = {
			k8s_namespace = "namespace",
			k8s_app       = "app",
			k8s_container = "container",
			k8s_pod       = "pod",
			namespace     = "namespace",
			app           = "app",
			container     = "container",
		}
	}
}

loki.process "sample_debug" {
	forward_to = [
		loki.echo.stub.receiver,
	]

	stage.drop {
		source              = "app"
		value               = "alloy"
		drop_counter_reason = "skip self"
	}

	stage.sampling {
		rate                = 0.01
		drop_counter_reason = "sample_debug"
	}
}

loki.echo "stub" { }
