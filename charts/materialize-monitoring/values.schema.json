{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "materialize-monitoring umbrella chart values",
  "description": "Stub schema. Tightened iteratively as values surface stabilizes. Subchart values are intentionally permissive — upstream schemas are not redeclared here.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "profile": {
      "type": "string",
      "enum": [
        "datadog-agent",
        "prometheus-remote-write",
        "otlp",
        "bundled-stack"
      ]
    },
    "tags": {
      "type": "object",
      "description": "Helm dependency tags. Group tags and per-chart tags are OR-combined; see values.yaml for the mapping.",
      "additionalProperties": false,
      "properties": {
        "pipeline": { "type": "boolean" },
        "bundled-backends": { "type": "boolean" },
        "cluster-metrics": { "type": "boolean" },
        "crds": { "type": "boolean" },
        "alloy-agent": { "type": "boolean" },
        "alloy-gateway": { "type": "boolean" },
        "loki": { "type": "boolean" },
        "thanos": { "type": "boolean" },
        "grafana": { "type": "boolean" },
        "alertmanager": { "type": "boolean" },
        "kube-state-metrics": { "type": "boolean" },
        "metrics-server": { "type": "boolean" },
        "prometheus-operator-crds": { "type": "boolean" }
      }
    },
    "materialize": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environmentLabel": { "type": "string" },
        "deploymentMode": {
          "type": "string",
          "enum": ["self-managed", "cloud", "byoc"]
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": true
    },
    "configurations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dashboards": { "type": "object" },
        "rules": { "type": "object" },
        "alerts": { "type": "object" },
        "scrapers": { "type": "object" }
      }
    }
  },
  "required": ["profile"]
}
