medium (base) workloads:
  1: |
    apiVersion: apps/v1
    kind: StatefulSet
    metadata:
      annotations: {}
      labels:
        app.kubernetes.io/component: memcached-chunks-cache
        app.kubernetes.io/instance: t
        app.kubernetes.io/name: loki
        app.kubernetes.io/version: 3.7.2
        helm.sh/chart: loki-15.0.1
        name: memcached-chunks-cache
      name: loki-chunks-cache
      namespace: loki
    spec:
      podManagementPolicy: Parallel
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: memcached-chunks-cache
          app.kubernetes.io/instance: t
          app.kubernetes.io/name: loki
          name: memcached-chunks-cache
      serviceName: loki-chunks-cache
      template:
        metadata:
          annotations: null
          labels:
            app.kubernetes.io/component: memcached-chunks-cache
            app.kubernetes.io/instance: t
            app.kubernetes.io/name: loki
            name: memcached-chunks-cache
        spec:
          affinity: {}
          containers:
            - args:
                - -m 2048
                - --extended=modern,track_sizes
                - -I 5m
                - -c 16384
                - -v
                - -u 11211
              env: null
              envFrom: null
              image: memcached:1.6.41-alpine
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 3
                initialDelaySeconds: 30
                periodSeconds: 10
                tcpSocket:
                  port: client
                timeoutSeconds: 5
              name: memcached
              ports:
                - containerPort: 11211
                  name: client
              readinessProbe:
                failureThreshold: 6
                initialDelaySeconds: 5
                periodSeconds: 5
                tcpSocket:
                  port: client
                timeoutSeconds: 3
              resources:
                limits:
                  memory: 2458Mi
                requests:
                  cpu: 500m
                  memory: 2458Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                seccompProfile:
