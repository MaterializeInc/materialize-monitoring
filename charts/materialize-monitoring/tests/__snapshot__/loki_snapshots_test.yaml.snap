                failureThreshold: 3
                initialDelaySeconds: 30
                periodSeconds: 10
                tcpSocket:
                  port: client
                timeoutSeconds: 5
              name: memcached
              ports:
                - containerPort: 11211
                  name: client
              readinessProbe:
                failureThreshold: 6
                initialDelaySeconds: 5
                periodSeconds: 5
                tcpSocket:
                  port: client
