                  port: http-metrics
                periodSeconds: 30
                successThreshold: 1
                timeoutSeconds: 1
              name: ruler
              ports:
                - containerPort: 3100
                  name: http-metrics
                  protocol: TCP
                - containerPort: 9095
                  name: grpc
                  protocol: TCP
                - containerPort: 7946
                  name: http-memberlist
                  protocol: TCP
              readinessProbe:
